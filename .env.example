# ============================================================
#  Arquivo de variáveis de ambiente — Projeto TCC
#  Copie este arquivo para ".env" e preencha os valores reais.
#  NUNCA suba o arquivo ".env" para o Git!
# ============================================================

# --- Facebook Graph API ---
# Obtenha em: https://developers.facebook.com/apps/
FB_APP_ID=seu_app_id_aqui
FB_APP_SECRET=seu_app_secret_aqui

# --- Google Maps API ---
# Obtenha em: https://console.cloud.google.com/
GOOGLEMAPS_KEY=sua_chave_google_maps_aqui

# --- Flask ---
# Use "true" apenas em desenvolvimento, nunca em produção
FLASK_DEBUG=false
